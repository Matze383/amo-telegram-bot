# Logging
# LOG_LEVEL: debug|info|warning|error (default: info)
LOG_LEVEL=info
# LOG_FORMAT: text|json (default: text)
LOG_FORMAT=text
# Optional file path for log output (default: stderr only)
# LOG_FILE=
# LOG_DEBUG_SCOPES: comma-separated component names to set to DEBUG (e.g.: ai.router,plugin.runtime)
# LOG_DEBUG_SCOPES=
# LOG_INCLUDE_PRIVATE_IDS: set to 1/true/yes/on to include unmasked IDs in structured logs (default: off)
# WARNING: Enabling logs sensitive identifiers (user IDs, chat IDs). Protect log files with appropriate permissions.
# LOG_INCLUDE_PRIVATE_IDS=0

# Telegram
BOT_TOKEN=replace_me
TELEGRAM_API_BASE=https://api.telegram.org
BOT_USERNAME=
POLL_TIMEOUT_SECONDS=30
POLL_LIMIT=100
POLL_RETRY_MAX_SECONDS=30
OFFSET_STATE_FILE=.state/offset.json

# Process control (optional)
# BOT_PID_FILE=.state/amo_bot.pid  # Path to PID file for --stop CLI option

# AI provider
AI_PROVIDER=ollama  # ollama (default), openai, anthropic, google, openrouter, groq, mistral, xai, deepseek, together, amazon-bedrock, litellm, lmstudio, vllm, sglang
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_SECONDS=30

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=anthropic/claude-opus-4-6
ANTHROPIC_TIMEOUT_SECONDS=30
ANTHROPIC_BASE_URL=https://api.anthropic.com

# Google/Gemini
# Set one of GEMINI_API_KEY or GOOGLE_API_KEY when AI_PROVIDER=google
GEMINI_API_KEY=
GOOGLE_API_KEY=
GEMINI_MODEL=google/gemini-3-flash-preview
GEMINI_TIMEOUT_SECONDS=30
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com

# OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/auto
OPENROUTER_TIMEOUT_SECONDS=30
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Groq
GROQ_API_KEY=
GROQ_MODEL=groq/llama-3.1-8b-instant
GROQ_TIMEOUT_SECONDS=30
# GROQ_BASE_URL=https://api.groq.com/openai/v1


# xAI
XAI_API_KEY=
XAI_MODEL=xai/grok-4.3
XAI_TIMEOUT_SECONDS=30
# XAI_BASE_URL=https://api.x.ai/v1

# DeepSeek (when AI_PROVIDER=deepseek)
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek/deepseek-v4-flash
DEEPSEEK_TIMEOUT_SECONDS=30
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1


# Together AI (when AI_PROVIDER=together)
TOGETHER_API_KEY=
TOGETHER_MODEL=together/moonshotai/Kimi-K2.5
TOGETHER_TIMEOUT_SECONDS=30
# TOGETHER_BASE_URL=https://api.together.xyz/v1

# Fireworks AI (OpenAI-compatible)
FIREWORKS_API_KEY=fireworks-credential-placeholder
FIREWORKS_MODEL=fireworks/accounts/fireworks/models/llama-v3p1-8b-instruct
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1
FIREWORKS_TIMEOUT_SECONDS=30

# Amazon Bedrock (when AI_PROVIDER=amazon-bedrock)
BEDROCK_MODEL=amazon-bedrock/anthropic.claude-3-haiku-20240307-v1:0
BEDROCK_REGION=
BEDROCK_TIMEOUT_SECONDS=30
# Optional explicit credentials (otherwise use ambient AWS profile/role)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

# Ollama
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=kimi-k2.6
OLLAMA_TIMEOUT_SECONDS=20
OLLAMA_MAX_PROMPT_CHARS=4000
OLLAMA_MAX_PREDICT_TOKENS=512
OLLAMA_MAX_RESPONSE_CHARS=1500
# OLLAMA_REQUEST_ENDPOINT=generate  # generate (default) or chat; invalid values fail startup validation
# OLLAMA_STREAMING_MODE=off  # off (default), collect_only, live_edit (parsed gate only; no live Telegram streaming)

# Optional: Ollama model policy (task-based model selection)
# OLLAMA_MODEL_POLICY_ENABLED=false
# OLLAMA_THINKING_MODEL=
# OLLAMA_NON_THINKING_MODEL=
# OLLAMA_THINKING_TASK_TYPES=web_research,sports,news,answer_synthesis
# OLLAMA_SIMPLE_PROMPT_MAX_CHARS=240
# OLLAMA_THINKING_TIMEOUT_SECONDS=
# OLLAMA_NON_THINKING_TIMEOUT_SECONDS=
# OLLAMA_THINKING_BUDGET_MAX_PROMPT_CHARS=
# OLLAMA_NON_THINKING_BUDGET_MAX_PROMPT_CHARS=

# Image Analysis (Ollama vision models allowlist)
# Comma-separated list of vision-capable models for image analysis when using Ollama provider.
# Default: llava,llama3.2-vision,qwen2.5vl
# Non-standard names (e.g., kimi-k2.5:cloud) can be explicitly allowed by adding to the list.
# IMAGE_ANALYSIS_OLLAMA_VISION_MODELS=llava,llama3.2-vision,qwen2.5vl

# Database
# Production: PostgreSQL with vector, pg_trgm, pgcrypto, and optional TimescaleDB extensions.
DATABASE_URL=postgresql+psycopg://amo_bot:<password>@<postgres-host>:5432/amo_bot
# Local tests/dev can still use SQLite:
# DATABASE_URL=sqlite:///./data/amo_bot.db

# Plugins
AMO_PLUGIN_DIR=./plugins

# WebUI (lokal, MVP)
WEBUI_HOST=127.0.0.1
WEBUI_PORT=8080
# Required for mutating WebUI routes (set a strong local value, do not commit real secrets)
WEBUI_PASSWORD=
# Required: Flask session signing key for WebUI (min 32 chars, generate e.g.:
# python -c "import secrets; print(secrets.token_urlsafe(48))")
WEBUI_SECRET_KEY=replace_with_strong_random_secret
# Server-side actor used for WebUI role mutations; required for POST /users/set-role audit integrity
WEBUI_OWNER_TELEGRAM_ID=
# Bearer token TTL for WebUI sessions (seconds)
WEBUI_SESSION_TTL_SECONDS=3600
# Enable when WebUI is exposed beyond trusted local/LAN usage
WEBUI_PUBLIC_MODE=false
# Require HTTPS assumptions for WebUI hardening (e.g. reverse proxy TLS)
WEBUI_REQUIRE_HTTPS=false
# Optional override for session cookie Secure flag (true/false). Empty = auto.
WEBUI_SESSION_COOKIE_SECURE=

# Mistral (when AI_PROVIDER=mistral)
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral/mistral-large-latest
MISTRAL_TIMEOUT_SECONDS=30
# MISTRAL_BASE_URL=https://api.mistral.ai/v1

# LM Studio (when AI_PROVIDER=lmstudio) - local OpenAI-compatible server
# LMSTUDIO_API_KEY=           # optional; omit for unauthenticated local servers
LMSTUDIO_MODEL=local-model
LMSTUDIO_TIMEOUT_SECONDS=60
LMSTUDIO_BASE_URL=http://127.0.0.1:1234/v1

# vLLM (when AI_PROVIDER=vllm) - local OpenAI-compatible server (e.g. OpenClaw backend)
# VLLM_API_KEY=               # optional; omit for unauthenticated local servers
VLLM_MODEL=                   # model name exposed by the vLLM server (required when AI_PROVIDER=vllm)
VLLM_TIMEOUT_SECONDS=60
VLLM_BASE_URL=http://127.0.0.1:8000/v1

# SGLang (when AI_PROVIDER=sglang) - local OpenAI-compatible server
# SGLANG_API_KEY=             # optional; omit for unauthenticated local servers
SGLANG_MODEL=                 # model name exposed by the SGLang server (required when AI_PROVIDER=sglang)
SGLANG_TIMEOUT_SECONDS=60
SGLANG_BASE_URL=http://127.0.0.1:8000/v1

# Websearch / SearXNG (optional)
# Base URL of your SearXNG instance (include protocol, no trailing slash)
# Example: http://localhost:8080 or https://searx.example.com
AMO_WEBSEARCH_SEARXNG_BASE_URL=
# Request timeout in seconds (default: 30)
AMO_WEBSEARCH_SEARXNG_TIMEOUT_SECONDS=30
# Maximum number of search results to return (default: 10)
AMO_WEBSEARCH_MAX_RESULTS=10
# Language preference for search results (default: auto, or specify like 'en-US', 'de-DE')
AMO_WEBSEARCH_SEARXNG_LANGUAGE=auto
# Comma-separated list of search categories (default: general)
# Examples: general, images, news, files, social_media
AMO_WEBSEARCH_SEARXNG_CATEGORIES=general

# Current-Info Search / SearchBroker (SearXNG primary, Brave fallback)
# Required for Current-Info queries (news, weather, sports, stocks)
# SearXNG instance URL (include protocol, no trailing slash)
AMO_SEARXNG_URL=
# Brave Search API key (optional, for fallback)
AMO_BRAVE_SEARCH_API_KEY=
# Fallback provider when SearXNG fails: 'brave' or empty to disable
AMO_SEARCH_FALLBACK_PROVIDER=
# Maximum results per search (default: 10)
AMO_SEARCH_MAX_RESULTS=10
# SearXNG request timeout in seconds (default: 30)
AMO_SEARXNG_TIMEOUT_SECONDS=30
# Brave Search request timeout in seconds (default: 30)
AMO_BRAVE_SEARCH_TIMEOUT_SECONDS=30
# Minimum distinct hosts in results to avoid spam (default: 3)
AMO_SEARCH_MIN_HOST_DIVERSITY=3
# Safesearch profile for SearXNG/Brave parameter mapping: off, moderate, strict (default: moderate)
# Note: SearX/SearXNG result snippets are intentionally NOT used as evidence; the system
# performs fail-closed scraping of actual page content instead.
AMO_SEARCH_SAFESEARCH=moderate
# Optional 2-letter country code for SearXNG/Brave parameter mapping (default: empty)
AMO_SEARCH_REGION=
# Optional YAML/JSON file for Current-Info intent profile tuning (default: empty, built-in defaults)
AMO_SEARCH_PROFILES_FILE=
# Current-Info document fetch timeout in seconds for followed result URLs (default: 5)
AMO_DOCUMENT_FETCH_TIMEOUT_SECONDS=5
# Maximum fetched document body size in bytes (default: 1000000)
AMO_DOCUMENT_FETCH_MAX_BYTES=1000000
# Maximum redirects while fetching a document (default: 3)
AMO_DOCUMENT_FETCH_MAX_REDIRECTS=3
# Prefer Crawlee for document fetching with httpx fallback (default: true)
AMO_DOCUMENT_FETCH_PREFER_CRAWLEE=true
# Enable Current-Info Telegram answers. For research-needed mutable facts,
# unavailable Current-Info fails closed instead of falling back to model priors.
AMO_CURRENT_INFO_ENABLED=false
# Front-end Current-Info answer budget in seconds, including synthesis; timed-out work may finish in the background (default: 8, allowed: >0 to 60)
AMO_CURRENT_INFO_TIMEOUT_SECONDS=8
# Background synthesis budget for late Current-Info answers (default: 60, allowed: >0 to 300)
AMO_CURRENT_INFO_LATE_SYNTHESIS_TIMEOUT_SECONDS=60
# Maximum Current-Info search results per Telegram answer (default: 10)
AMO_CURRENT_INFO_MAX_RESULTS=10
# Maximum followed documents per Current-Info Telegram answer (default: 3)
AMO_CURRENT_INFO_MAX_DOCUMENTS=3
# Maximum search-provider calls per Current-Info response (default: 2)
AMO_CURRENT_INFO_MAX_SEARCH_PROVIDER_RUNS_PER_RESPONSE=2
# Maximum document-fetch calls per Current-Info response (default: 3)
AMO_CURRENT_INFO_MAX_FETCH_RUNS_PER_RESPONSE=3
# Combined search/fetch provider-call budget per Current-Info response (default: 8)
AMO_CURRENT_INFO_MAX_TOTAL_PROVIDER_RUNS_PER_RESPONSE=8
# Per-provider in-memory Current-Info search rate limit per minute (default: 60)
AMO_CURRENT_INFO_PROVIDER_RATE_LIMIT_PER_MINUTE=60
# Additional in-memory Brave Search quota guard per minute (default: 30)
AMO_BRAVE_SEARCH_QUOTA_PER_MINUTE=30
# Maximum concurrent Crawlee document fetches per host (default: 2)
AMO_CRAWLEE_MAX_CONCURRENT_PER_HOST=2
# Include operator budget diagnostics in Current-Info answer metadata (default: false)
AMO_CURRENT_INFO_DEBUG_OUTPUT=false
# TTL for realtime/news cache entries in seconds (default: 900)
AMO_CURRENT_INFO_CACHE_REALTIME_TTL_SECONDS=900
# TTL for docs/official cache entries in seconds (default: 604800)
AMO_CURRENT_INFO_CACHE_DOCS_TTL_SECONDS=604800
# TTL for general cache entries in seconds (default: 86400)
AMO_CURRENT_INFO_CACHE_GENERAL_TTL_SECONDS=86400
# TTL for unknown source types in seconds (default: 3600)
AMO_CURRENT_INFO_CACHE_UNKNOWN_TTL_SECONDS=3600
# Maximum retained Current-Info documents before pruning oldest entries (default: 5000)
AMO_CURRENT_INFO_CACHE_MAX_DOCUMENTS=5000
# Retention window for old/expired Current-Info cache documents in days (default: 30)
AMO_CURRENT_INFO_CACHE_RETENTION_DAYS=30
# Maximum text length per keyword-retrieval chunk (default: 1200)
AMO_CURRENT_INFO_CACHE_MAX_CHUNK_CHARS=1200
# Maximum retrieval chunks stored per document (default: 12)
AMO_CURRENT_INFO_CACHE_MAX_CHUNKS_PER_DOCUMENT=12

# Current-Info Vector Search / PostgreSQL pgvector (optional)
# Enable semantic retrieval over Current-Info chunks. PostgreSQL remains the source of truth;
# pgvector stores vectors, chunk pointers, and source metadata only. Private user queries are NOT stored as vectors.
# Set to true to enable vector semantic retrieval (default: false)
AMO_VECTOR_ENABLED=false
# Vector database provider: postgres (default) or legacy qdrant
AMO_VECTOR_PROVIDER=postgres
# Legacy Qdrant base URL; QDRANT_URL is accepted as an alias only for AMO_VECTOR_PROVIDER=qdrant
AMO_VECTOR_URL=
# Optional legacy Qdrant API key; QDRANT_API_KEY is accepted as an alias. Store only in env/secrets, never in code or docs
AMO_VECTOR_API_KEY=
# Legacy Qdrant collection for Current-Info chunk vectors (default: current_info_chunks)
AMO_VECTOR_COLLECTION=current_info_chunks
# Embedding provider for chunk/query vectors: ollama or openai (default: ollama)
AMO_VECTOR_EMBEDDING_PROVIDER=ollama
# Embedding model used for Current-Info vectors (default: nomic-embed-text-v2-moe:latest)
AMO_VECTOR_EMBEDDING_MODEL=nomic-embed-text-v2-moe:latest
# Timeout for vector DB and embedding requests in seconds (default: 3)
AMO_VECTOR_TIMEOUT_SECONDS=3

# GPT-Researcher / Deep Research (optional)
# Requires dependencies from requirements.txt, a reachable SearXNG instance configured with AMO_SEARXNG_URL,
# which AMO passes to GPT-Researcher as SEARX_URL,
# research LLM models, and embeddings. Restart the bot after dependency or env changes.
# Keep disabled unless the required services are reachable; research-needed paths fail closed
# instead of guessing from stale model knowledge when GPT-Researcher is unavailable.
AMO_GPT_RESEARCHER_ENABLED=false
# LLM provider id for GPT-Researcher model names (default: ollama)
AMO_RESEARCH_MODEL_PROVIDER=ollama
# Optional explicit research models. Empty values fall back to Ollama policy/default models:
# fast -> OLLAMA_NON_THINKING_MODEL or OLLAMA_MODEL
AMO_RESEARCH_FAST_MODEL=
# smart -> OLLAMA_MODEL
AMO_RESEARCH_SMART_MODEL=
# strategic -> OLLAMA_THINKING_MODEL or OLLAMA_MODEL
AMO_RESEARCH_STRATEGIC_MODEL=
# Maximum source URLs returned from GPT-Researcher (default: 10, allowed: 1 to 25)
AMO_RESEARCH_MAX_SOURCES=10
# Maximum context characters retained from GPT-Researcher evidence (default: 16000, allowed: 1000 to 100000)
AMO_RESEARCH_MAX_CONTEXT_CHARS=16000
# Deep-research breadth, depth, and concurrency budgets (defaults: 3, 2, 4; allowed: breadth/depth 1 to 10, concurrency 1 to 20)
AMO_RESEARCH_DEEP_BREADTH=3
AMO_RESEARCH_DEEP_DEPTH=2
AMO_RESEARCH_DEEP_CONCURRENCY=4
# pgvector collection used by GPT-Researcher. PostgreSQL remains the source of truth.
AMO_RESEARCH_VECTOR_COLLECTION=amo_gpt_researcher_chunks
# Target report length in words (default: 1200, allowed: 200 to 5000)
AMO_RESEARCH_REPORT_WORDS=1200
# Timeout for GPT-Researcher deep research operations in seconds (default: 360, allowed: >0 to 900)
AMO_RESEARCH_TIMEOUT_SECONDS=360

# GPT-Researcher Role Skills (optional)
# Directory containing role-specific skill files for fast/smart/strategic LLM stages
# AMO_RESEARCH_ROLE_SKILLS_DIR=skills/gpt_researcher
# Path overrides for individual skill files (default: auto-resolve from ROLE_SKILLS_DIR)
# AMO_RESEARCH_FAST_SKILL_PATH=skills/gpt_researcher/fast/SKILL.md
# AMO_RESEARCH_SMART_SKILL_PATH=skills/gpt_researcher/smart/SKILL.md
# AMO_RESEARCH_STRATEGIC_SKILL_PATH=skills/gpt_researcher/strategic/SKILL.md
# Maximum characters per role skill file (default: 2000, allowed: 500 to 10000)
# AMO_RESEARCH_ROLE_SKILL_MAX_CHARS=2000

# Daily Memory Runtime (OpenClaw-like Light Memory)
# Set MEMORY_DAILY_ENABLED=1 to activate periodic daily memory summarization.
# This is a lighter alternative to full Dreaming — creates bounded daily summaries per scope.
# Runs during the same night window as Dreaming but produces different output.
# Can run alongside Dreaming or standalone.
# MEMORY_DAILY_ENABLED=0
# MEMORY_DAILY_INTERVAL_SECONDS=21600  # interval between runs in seconds (default: 6 hours)
# MEMORY_DAILY_MAX_INPUT_MESSAGES=200  # max messages to process per scope per run
# MEMORY_DAILY_MAX_CHARS_PER_MESSAGE=500  # truncate messages exceeding this length
# MEMORY_DAILY_MAX_SUMMARY_CHARS=6000  # max length of generated daily summary
# MEMORY_DAILY_MIN_MESSAGES=1  # minimum messages required to generate a summary
# MEMORY_DAILY_MAX_SCOPES_PER_RUN=10  # max scopes to process in a single run

# Dreaming / Memory-Curation Runtime (disabled by default)
# Set DREAMING_ENABLED=1 to activate the periodic memory maintenance + curation background task.
# No-overlap: at most one run executes at a time (internal asyncio.Lock).
# DREAMING_AUTO_APPROVE_MODE=1 bypasses human review for curated candidates — use with extreme care.
#
# Nightly dreaming window (default Europe/Berlin 02:00–05:00):
# Dreaming only runs within this window — no hourly full scans during the day.
# DREAMING_ENABLED=0
# DREAMING_INTERVAL_SECONDS=0  # not used in nightly mode; kept for compatibility
# DREAMING_TIMEOUT_SECONDS=300
# DREAMING_MAX_DAILY_CANDIDATES_PER_SCOPE=3
# DREAMING_MAX_PROMOTIONS_PER_SCOPE=2
# DREAMING_AUTO_APPROVE_MODE=0
# DREAMING_LOG_LEVEL=info  # debug|info|warning|error (default: info)
# Dreams per-batch limit
# DREAMING_MAX_SCOPES_PER_BATCH=3
# DREAMING_BATCH_PAUSE_SECONDS=300  # pause between batches
# DREAMING_JITTER_SECONDS=120  # random jitter added to each pause
# DREAMING_MIN_DAILY_MEMORIES=1  # scope needs at least N daily memories today to be processed
# DREAMING_LOOKBACK_DAYS=7  # look back N days to count daily memories (default 7)
# DREAMING_TIMEZONE=Europe/Berlin  # window timezone
# DREAMING_WINDOW_START=02:00
# DREAMING_WINDOW_END=05:00
